<Project>

  <PropertyGroup>
    <Version Condition="'$(Version)' == ''">1.0.0</Version>
  </PropertyGroup>

  <ItemGroup Condition="'$(MSBuildProjectName)' != 'Merchello.ArchitectureAnalyzers' AND '$(MSBuildProjectName)' != 'Merchello.StarterSite.Template'">
    <ProjectReference Include="$(MSBuildThisFileDirectory)Merchello.ArchitectureAnalyzers\Merchello.ArchitectureAnalyzers.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      SetTargetFramework="TargetFramework=netstandard2.0"
                      GlobalPropertiesToRemove="TargetFramework;TargetFrameworks"
                      PrivateAssets="all" />
  </ItemGroup>

</Project>
