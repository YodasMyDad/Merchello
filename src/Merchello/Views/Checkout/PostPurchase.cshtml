@model CheckoutViewModel
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
    var invoiceId = ViewData["InvoiceId"] as Guid?;
    var confirmationUrl = ViewData["ConfirmationUrl"] as string ?? "/";
}

@if (invoiceId == null)
{
    <!-- Order Not Found -->
    <div class="max-w-2xl mx-auto text-center py-12">
        <div class="mb-6">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-red-100 rounded-full">
                <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </div>
        </div>

        <h1 class="font-heading text-3xl font-semibold text-gray-900 mb-2">Order not found</h1>
        <p class="text-gray-600 mb-8">We couldn't find the order you're looking for. It may have expired or the link is invalid.</p>

        <a href="/"
           class="inline-block px-8 py-3 bg-primary text-white font-medium rounded-lg hover:opacity-90 focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all">
            Continue Shopping
        </a>
    </div>
}
else
{
    <div class="max-w-5xl mx-auto py-12" data-post-purchase data-invoice-id="@invoiceId" data-confirmation-url="@confirmationUrl">
        <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-xl mb-8">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div class="flex items-center gap-4">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full">
                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm text-gray-600">Payment successful</p>
                        <h1 class="font-heading text-2xl lg:text-3xl font-semibold text-gray-900">Before your confirmation</h1>
                        <p class="text-gray-600 mt-2">Add a last item with one click. Your saved payment method will be charged.</p>
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <button type="button" class="checkout-button-secondary" data-post-purchase-skip>
                        Show my order confirmation
                    </button>
                    <p class="text-xs text-gray-500 text-center" data-post-purchase-timer></p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 space-y-6" data-post-purchase-content>
                <div class="checkout-skeleton h-6 w-48"></div>
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="border border-gray-200 rounded-lg p-4">
                            <div class="checkout-skeleton h-32 w-full mb-3"></div>
                            <div class="checkout-skeleton h-4 w-3/4 mb-2"></div>
                            <div class="checkout-skeleton h-4 w-1/2"></div>
                        </div>
                    }
                </div>
            </div>

            <aside class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                <h2 class="font-medium text-gray-900 mb-2">Saved payment method</h2>
                <p class="text-sm text-gray-700" data-post-purchase-card></p>
                <p class="text-xs text-gray-500 mt-3">You can review your order after this step.</p>
            </aside>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/checkout/post-purchase.js"></script>
}
