@model CheckoutViewModel
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
    var session = Model.Session;
    var basket = Model.Basket;
    var billingAddress = session?.BillingAddress;
    var shippingAddress = session?.ShippingSameAsBilling == true ? billingAddress : session?.ShippingAddress;
    var currencySymbol = basket?.CurrencySymbol ?? "£";
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-0" x-data="checkoutPayment()">
    <!-- Screen reader announcements -->
    <div aria-live="polite" aria-atomic="true" class="sr-only" x-text="announcement"></div>

    <!-- Left Column: Payment -->
    <div class="pt-8 lg:pr-12 pb-24 lg:pb-8">
        <!-- Contact, Ship to & Shipping Summary (Shopify style) -->
        <div class="mb-6 border border-gray-200 rounded-lg divide-y divide-gray-200">
            <div class="flex items-center justify-between p-4">
                <div class="flex items-start gap-4 flex-1">
                    <span class="text-sm text-gray-500 w-16 flex-shrink-0">Contact</span>
                    <p class="text-sm text-gray-900">@(billingAddress?.Email ?? "Not provided")</p>
                </div>
                <a href="/checkout/information" class="text-sm text-accent hover:underline">Change</a>
            </div>
            <div class="flex items-center justify-between p-4">
                <div class="flex items-start gap-4 flex-1">
                    <span class="text-sm text-gray-500 w-16 flex-shrink-0">Ship to</span>
                    <p class="text-sm text-gray-900">
                        @if (shippingAddress != null)
                        {
                            @($"{shippingAddress.AddressOne}, {shippingAddress.TownCity}, {shippingAddress.PostalCode}")
                        }
                        else
                        {
                            <text>Not provided</text>
                        }
                    </p>
                </div>
                <a href="/checkout/information" class="text-sm text-accent hover:underline">Change</a>
            </div>
            <div class="flex items-center justify-between p-4">
                <div class="flex items-start gap-4 flex-1">
                    <span class="text-sm text-gray-500 w-16 flex-shrink-0">Method</span>
                    <p class="text-sm text-gray-900">
                        @if (basket?.Shipping > 0)
                        {
                            @($"{currencySymbol}{basket.Shipping:N2}")
                        }
                        else
                        {
                            <text>Free shipping</text>
                        }
                    </p>
                </div>
                <a href="/checkout/shipping" class="text-sm text-accent hover:underline">Change</a>
            </div>
        </div>

        <!-- Payment Section -->
        <div class="mb-6">
            <h2 class="font-heading text-xl font-normal mb-4">Payment</h2>

            <!-- Loading State (Skeleton) -->
            <div x-show="isLoading" class="space-y-4" role="status" aria-label="Loading payment methods" :aria-busy="isLoading">
                <div class="flex gap-2">
                    <div class="h-12 flex-1 checkout-skeleton rounded-lg"></div>
                    <div class="h-12 flex-1 checkout-skeleton rounded-lg"></div>
                </div>
                <div class="h-40 checkout-skeleton rounded-lg"></div>
                <span class="sr-only">Loading payment methods...</span>
            </div>

            <!-- Error State -->
            <div x-show="loadError" x-cloak role="alert" class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-700">
                <p class="font-medium">Failed to load payment methods</p>
                <p class="text-sm mt-1" x-text="loadError"></p>
                <button type="button" @@click="loadPaymentMethods()" class="mt-2 text-sm underline checkout-link">Try again</button>
            </div>

            <!-- No Methods Available -->
            <div x-show="!isLoading && !loadError && paymentMethods.length === 0" x-cloak class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-yellow-700">
                <p>No payment methods are currently available. Please contact support.</p>
            </div>

            <!-- Payment Methods (Provider-Agnostic Layout) -->
            <div x-show="!isLoading && !loadError && paymentMethods.length > 0" x-cloak class="space-y-6">

                <!-- Express Checkout Section (Apple Pay, Google Pay, PayPal, Venmo) -->
                <template x-if="expressMethods.length > 0">
                    <div class="express-checkout-section">
                        <div class="flex flex-wrap gap-2 mb-4" id="express-checkout-buttons">
                            <template x-for="method in expressMethods" :key="method.providerAlias + '-' + method.methodAlias">
                                <button type="button"
                                        @@click="initiateExpressCheckout(method)"
                                        :disabled="isSubmitting"
                                        class="express-checkout-btn flex-1 min-w-[140px] h-12 px-4 flex items-center justify-center gap-2 bg-gray-100 hover:bg-gray-200 border border-gray-300 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                    <span x-html="getMethodIcon(method)" class="w-6 h-6 flex items-center justify-center" aria-hidden="true"></span>
                                    <span class="font-medium text-sm" x-text="method.displayName"></span>
                                </button>
                            </template>
                        </div>
                        <div class="relative flex items-center my-4">
                            <div class="flex-grow border-t border-gray-200"></div>
                            <span class="flex-shrink mx-4 text-sm text-gray-500">or pay with card</span>
                            <div class="flex-grow border-t border-gray-200"></div>
                        </div>
                    </div>
                </template>

                <!-- Primary Payment Method (Cards) -->
                <template x-if="cardMethod">
                    <div class="primary-payment-section">
                        <div class="p-4 border border-accent rounded-lg bg-accent/5"
                             :class="{ 'border-accent': selectedMethod?.methodAlias === cardMethod.methodAlias }">
                            <div class="flex items-center gap-3 mb-4">
                                <span x-html="getMethodIcon(cardMethod)" class="w-8 h-5" aria-hidden="true"></span>
                                <span class="font-medium" x-text="cardMethod.displayName"></span>
                            </div>
                            <!-- Card form container - adapter renders here -->
                            <div id="primary-card-form" class="card-form-container">
                                <div x-show="!cardFormReady && selectedMethod?.methodAlias === cardMethod.methodAlias" class="py-4 text-center text-gray-500">
                                    <svg class="animate-spin h-6 w-6 mx-auto mb-2" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    Loading secure card form...
                                </div>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Other Payment Methods Section (iDEAL, Bancontact, SEPA, etc.) -->
                <template x-if="otherMethods.length > 0">
                    <div class="other-payment-section">
                        <div class="relative flex items-center my-4">
                            <div class="flex-grow border-t border-gray-200"></div>
                            <span class="flex-shrink mx-4 text-sm text-gray-500">other payment methods</span>
                            <div class="flex-grow border-t border-gray-200"></div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                            <template x-for="method in otherMethods" :key="method.providerAlias + '-' + method.methodAlias">
                                <button type="button"
                                        @@click="initiateOtherPayment(method)"
                                        :disabled="isSubmitting"
                                        class="other-payment-btn p-4 flex items-center gap-3 bg-white hover:bg-gray-50 border border-gray-200 hover:border-gray-300 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed text-left">
                                    <span x-html="getMethodIcon(method)" class="w-8 h-6 flex-shrink-0 flex items-center justify-center" aria-hidden="true"></span>
                                    <div class="flex-1 min-w-0">
                                        <p class="font-medium text-gray-900 text-sm" x-text="method.displayName"></p>
                                        <p class="text-xs text-gray-500 truncate" x-text="method.description || getMethodDescription(method)"></p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </button>
                            </template>
                        </div>
                    </div>
                </template>

                <!-- Fallback: Show as list if no card method (e.g., only local payments) -->
                <template x-if="!cardMethod && otherMethods.length === 0 && standardMethods.length > 0">
                    <div class="fallback-payment-section space-y-3" role="radiogroup" aria-label="Payment methods">
                        <template x-for="method in standardMethods" :key="method.providerAlias + '-' + method.methodAlias">
                            <label class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-accent transition-colors checkout-touch-target"
                                   :class="{ 'border-accent bg-accent/5': selectedMethod?.providerAlias === method.providerAlias && selectedMethod?.methodAlias === method.methodAlias }">
                                <span class="checkout-checkbox-wrapper">
                                    <input type="radio"
                                           name="payment"
                                           :id="'payment-' + method.providerAlias + '-' + method.methodAlias"
                                           :value="method.providerAlias + ':' + method.methodAlias"
                                           @@change="selectMethod(method)"
                                           :checked="selectedMethod?.providerAlias === method.providerAlias && selectedMethod?.methodAlias === method.methodAlias"
                                           class="w-5 h-5 text-accent focus:ring-accent" />
                                </span>
                                <div class="flex-1">
                                    <p class="font-medium text-gray-900" x-text="method.displayName"></p>
                                    <p class="text-sm text-gray-500" x-text="method.description || getMethodDescription(method)"></p>
                                </div>
                                <div x-html="getMethodIcon(method)" aria-hidden="true"></div>
                            </label>
                        </template>
                    </div>
                </template>

            </div>
        </div>

        <!-- HostedFields Container (for inline card entry) -->
        <div id="hosted-fields-container" x-show="selectedMethod && selectedMethod.integrationType === 10" x-cloak x-transition class="mb-6">
            <div class="p-4 border border-gray-200 rounded-lg space-y-4">
                <!-- Placeholder for provider SDK to render fields -->
                <div id="payment-form-fields">
                    <div x-show="!hostedFieldsReady" class="text-center py-4 text-gray-500">
                        <svg class="animate-spin h-6 w-6 mx-auto mb-2" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Loading card fields...
                    </div>
                </div>
            </div>
        </div>

        <!-- Widget Container (for Apple Pay, Google Pay, PayPal buttons) -->
        <div id="widget-container" x-show="selectedMethod && selectedMethod.integrationType === 20" x-cloak x-transition class="mb-6">
            <div class="p-4 border border-gray-200 rounded-lg">
                <!-- Placeholder for provider widget -->
                <div id="payment-widget">
                    <div x-show="!widgetReady" class="text-center py-4 text-gray-500">
                        Loading payment widget...
                    </div>
                </div>
            </div>
        </div>

        <!-- DirectForm Container (for manual payment fields) -->
        <div id="direct-form-container" x-show="selectedMethod && selectedMethod.integrationType === 30" x-cloak x-transition class="mb-6">
            <div class="p-4 border border-gray-200 rounded-lg">
                <!-- Dynamic form fields will be rendered here -->
                <div id="direct-form-fields"></div>
            </div>
        </div>

        <!-- Payment Error Message -->
        <div x-show="paymentError" x-cloak role="alert" class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700">
            <p class="font-medium">Payment failed</p>
            <p class="text-sm mt-1" x-text="paymentError"></p>
        </div>

        <!-- Billing Address Toggle -->
        <div class="mb-6">
            <label class="inline-flex items-center gap-3 cursor-pointer checkout-touch-target">
                <span class="checkout-checkbox-wrapper">
                    <input type="checkbox"
                           id="billing-same-as-shipping"
                           x-model="billingSameAsShipping"
                           class="w-5 h-5 rounded border-gray-300 text-accent focus:ring-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2" />
                </span>
                <span class="text-sm text-gray-700">Billing address same as shipping</span>
            </label>
        </div>

        <!-- Navigation Buttons (Desktop) -->
        <div class="mt-8 hidden lg:flex items-center justify-between">
            <a href="/checkout/shipping" class="checkout-link flex items-center gap-2">
                <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Return to shipping
            </a>

            <button type="button"
                    @@click="submitPayment"
                    :disabled="!selectedMethod || isSubmitting"
                    :aria-busy="isSubmitting"
                    class="checkout-button-primary">
                <span x-show="!isSubmitting">
                    <template x-if="selectedMethod && selectedMethod.integrationType === 0">
                        <span>Continue to Payment</span>
                    </template>
                    <template x-if="!selectedMethod || selectedMethod.integrationType !== 0">
                        <span>Pay Now</span>
                    </template>
                </span>
                <span x-show="isSubmitting" x-cloak class="flex items-center gap-2">
                    <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Processing...</span>
                </span>
            </button>
        </div>
    </div>

    <!-- Right Column: Order Summary -->
    <div class="relative lg:border-l lg:border-gray-200">
        <!-- Background extending to viewport edge -->
        <div class="hidden lg:block absolute inset-y-0 left-0 w-[200vw] bg-[#fafafa] -z-10"></div>
        <div class="lg:pl-8 lg:pt-8 lg:pr-8">
            @await Html.PartialAsync("~/Views/Checkout/_OrderSummary.cshtml")
        </div>
    </div>

    <!-- Mobile Sticky Action Bar -->
    <div class="checkout-sticky-actions lg:hidden">
        <div class="flex flex-col gap-3">
            <button type="button"
                    @@click="submitPayment"
                    :disabled="!selectedMethod || isSubmitting"
                    :aria-busy="isSubmitting"
                    class="w-full checkout-button-primary">
                <span x-show="!isSubmitting">
                    <template x-if="selectedMethod && selectedMethod.integrationType === 0">
                        <span>Continue to Payment</span>
                    </template>
                    <template x-if="!selectedMethod || selectedMethod.integrationType !== 0">
                        <span>Pay Now</span>
                    </template>
                </span>
                <span x-show="isSubmitting" x-cloak class="flex items-center justify-center gap-2">
                    <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Processing...</span>
                </span>
            </button>
            <a href="/checkout/shipping" class="text-center checkout-link text-sm">
                Return to shipping
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/checkout/payment.js"></script>
    <script>
        function checkoutPayment() {
            return {
                // State
                paymentMethods: [],
                selectedMethod: null,
                billingSameAsShipping: true,
                isLoading: true,
                isSubmitting: false,
                loadError: null,
                paymentError: null,
                hostedFieldsReady: false,
                widgetReady: false,
                cardFormReady: false,
                currentSession: null,
                announcement: '',
                activeOtherMethodContainer: null,

                // Integration type constants
                IntegrationType: {
                    Redirect: 0,
                    HostedFields: 10,
                    Widget: 20,
                    DirectForm: 30
                },

                // Computed: Express checkout methods (Apple Pay, Google Pay, PayPal, Venmo)
                get expressMethods() {
                    return this.paymentMethods.filter(m => m.isExpressCheckout);
                },

                // Computed: Standard (non-express) methods
                get standardMethods() {
                    return this.paymentMethods.filter(m => !m.isExpressCheckout);
                },

                // Computed: Card method (for primary form display)
                get cardMethod() {
                    return this.standardMethods.find(m =>
                        m.methodAlias === 'cards' ||
                        m.methodAlias === 'card' ||
                        m.methodType === 0 // PaymentMethodType.Cards
                    );
                },

                // Computed: Other standard methods (excluding cards) - iDEAL, Bancontact, SEPA, etc.
                get otherMethods() {
                    return this.standardMethods.filter(m =>
                        m.methodAlias !== 'cards' &&
                        m.methodAlias !== 'card' &&
                        m.methodType !== 0
                    );
                },

                // Lifecycle
                async init() {
                    await this.loadPaymentMethods();

                    // Auto-select cards if available
                    if (this.cardMethod) {
                        await this.selectMethod(this.cardMethod);
                    }

                    // Emit analytics event for payment step
                    if (window.MerchelloCheckout && window.merchelloCheckoutData) {
                        window.MerchelloCheckout.emit('checkout:payment_initiated', {
                            ...window.merchelloCheckoutData,
                            payment_methods_count: this.paymentMethods.length
                        });
                    }
                },

                // Announce message to screen readers
                announce(message) {
                    this.announcement = '';
                    setTimeout(() => {
                        this.announcement = message;
                    }, 100);
                },

                // Load payment methods from API
                async loadPaymentMethods() {
                    this.isLoading = true;
                    this.loadError = null;

                    try {
                        this.paymentMethods = await MerchelloPayment.getPaymentMethods();

                        // Auto-select first method if only one
                        if (this.paymentMethods.length === 1) {
                            await this.selectMethod(this.paymentMethods[0]);
                        }
                    } catch (error) {
                        console.error('Failed to load payment methods:', error);
                        this.loadError = error.message || 'Failed to load payment methods';
                    } finally {
                        this.isLoading = false;
                    }
                },

                // Select a payment method
                async selectMethod(method) {
                    this.selectedMethod = method;
                    this.paymentError = null;
                    this.hostedFieldsReady = false;
                    this.widgetReady = false;
                    this.cardFormReady = false;

                    // Announce selection to screen readers
                    this.announce(`Selected ${method.displayName} payment method`);

                    // Clear any previous SDK containers
                    const hostedFieldsContainer = document.getElementById('payment-form-fields');
                    const widgetContainer = document.getElementById('payment-widget');
                    const directFormContainer = document.getElementById('direct-form-fields');
                    const cardFormContainer = document.getElementById('primary-card-form');

                    if (hostedFieldsContainer) hostedFieldsContainer.innerHTML = '';
                    if (widgetContainer) widgetContainer.innerHTML = '';
                    if (directFormContainer) directFormContainer.innerHTML = '';

                    // If this is a card method, initialize the card form immediately
                    if (method.methodAlias === 'cards' || method.methodAlias === 'card' || method.methodType === 0) {
                        await this.initializeCardForm(method);
                    }
                },

                // Initialize the card form for the primary payment method
                async initializeCardForm(method) {
                    const container = document.getElementById('primary-card-form');
                    if (!container) return;

                    this.cardFormReady = false;
                    this.paymentError = null;

                    try {
                        const returnUrl = window.location.origin + '/checkout/return';
                        const cancelUrl = window.location.origin + '/checkout/cancel';

                        // Create payment session
                        const session = await MerchelloPayment.initiatePayment(
                            method.providerAlias,
                            method.methodAlias,
                            returnUrl,
                            cancelUrl
                        );

                        this.currentSession = session;

                        // Handle the payment flow based on integration type
                        await MerchelloPayment.handlePaymentFlow(session, {
                            containerId: 'primary-card-form',
                            onReady: () => {
                                this.cardFormReady = true;
                            },
                            onError: (error) => {
                                this.paymentError = error.message || 'Failed to load card form';
                            }
                        });
                    } catch (error) {
                        console.error('Failed to initialize card form:', error);
                        this.paymentError = error.message || 'Failed to load card form. Please try again.';
                    }
                },

                // Initiate express checkout (Apple Pay, Google Pay, PayPal, Venmo)
                async initiateExpressCheckout(method) {
                    if (this.isSubmitting) return;

                    this.isSubmitting = true;
                    this.paymentError = null;
                    this.announce(`Starting ${method.displayName} payment...`);

                    try {
                        const returnUrl = window.location.origin + '/checkout/return';
                        const cancelUrl = window.location.origin + '/checkout/cancel';

                        // Create payment session
                        const session = await MerchelloPayment.initiatePayment(
                            method.providerAlias,
                            method.methodAlias,
                            returnUrl,
                            cancelUrl
                        );

                        this.currentSession = session;
                        this.selectedMethod = method;

                        // For express checkout, the adapter handles everything
                        await MerchelloPayment.handlePaymentFlow(session, {
                            containerId: 'express-checkout-buttons',
                            onReady: () => {
                                this.widgetReady = true;
                            },
                            onError: (error) => {
                                this.paymentError = error.message || 'Express checkout failed';
                            }
                        });
                    } catch (error) {
                        console.error('Express checkout failed:', error);
                        this.paymentError = error.message || 'Payment failed. Please try again.';
                        this.announce(this.paymentError);
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                // Initiate other payment method (iDEAL, Bancontact, SEPA, etc.)
                async initiateOtherPayment(method) {
                    if (this.isSubmitting) return;

                    this.isSubmitting = true;
                    this.paymentError = null;
                    this.selectedMethod = method;
                    this.announce(`Starting ${method.displayName} payment...`);

                    try {
                        const returnUrl = window.location.origin + '/checkout/return';
                        const cancelUrl = window.location.origin + '/checkout/cancel';

                        // Create payment session
                        const session = await MerchelloPayment.initiatePayment(
                            method.providerAlias,
                            method.methodAlias,
                            returnUrl,
                            cancelUrl
                        );

                        this.currentSession = session;

                        // Handle based on integration type
                        if (session.integrationType === this.IntegrationType.Redirect) {
                            // Redirect to external payment page
                            if (session.redirectUrl) {
                                window.location.href = session.redirectUrl;
                            }
                        } else if (session.integrationType === this.IntegrationType.Widget) {
                            // Show widget in a modal or expand section
                            const widgetContainer = document.getElementById('payment-widget');
                            if (widgetContainer) {
                                widgetContainer.innerHTML = '';
                                await MerchelloPayment.handlePaymentFlow(session, {
                                    containerId: 'payment-widget',
                                    onReady: () => {
                                        this.widgetReady = true;
                                    },
                                    onError: (error) => {
                                        this.paymentError = error.message;
                                    }
                                });
                            }
                        }
                    } catch (error) {
                        console.error('Payment failed:', error);
                        this.paymentError = error.message || 'Payment failed. Please try again.';
                        this.announce(this.paymentError);
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                // Get method description based on type
                getMethodDescription(method) {
                    switch (method.integrationType) {
                        case this.IntegrationType.Redirect:
                            return 'You will be redirected to complete payment';
                        case this.IntegrationType.HostedFields:
                            return 'Enter your card details securely';
                        case this.IntegrationType.Widget:
                            return 'Quick and easy payment';
                        case this.IntegrationType.DirectForm:
                            return 'Complete payment details';
                        default:
                            return '';
                    }
                },

                // Get method icon HTML
                getMethodIcon(method) {
                    return MerchelloPayment.getMethodIcon(method);
                },

                // Submit payment
                async submitPayment() {
                    if (!this.selectedMethod || this.isSubmitting) return;

                    this.isSubmitting = true;
                    this.paymentError = null;
                    this.announce('Processing payment...');

                    try {
                        const returnUrl = window.location.origin + '/checkout/return';
                        const cancelUrl = window.location.origin + '/checkout/cancel';

                        // Initiate payment - creates invoice and payment session
                        const session = await MerchelloPayment.initiatePayment(
                            this.selectedMethod.providerAlias,
                            this.selectedMethod.methodAlias,
                            returnUrl,
                            cancelUrl
                        );

                        this.currentSession = session;

                        // Handle the payment flow based on integration type
                        await this.handlePaymentFlow(session);

                    } catch (error) {
                        console.error('Payment failed:', error);
                        this.paymentError = error.message || 'Payment failed. Please try again.';
                        this.announce(this.paymentError);
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                // Handle payment flow based on integration type
                async handlePaymentFlow(session) {
                    switch (session.integrationType) {
                        case this.IntegrationType.Redirect:
                            // Redirect to external payment page
                            if (session.redirectUrl) {
                                window.location.href = session.redirectUrl;
                            } else {
                                throw new Error('No redirect URL provided');
                            }
                            break;

                        case this.IntegrationType.HostedFields:
                            // Load SDK and render inline card fields
                            await this.setupHostedFields(session);
                            break;

                        case this.IntegrationType.Widget:
                            // Load SDK and render provider widget
                            await this.setupWidget(session);
                            break;

                        case this.IntegrationType.DirectForm:
                            // Render form fields
                            await this.setupDirectForm(session);
                            break;

                        default:
                            throw new Error(`Unknown integration type: ${session.integrationType}`);
                    }
                },

                // Setup hosted fields (inline card entry)
                async setupHostedFields(session) {
                    const container = document.getElementById('payment-form-fields');
                    if (!container) return;

                    try {
                        // Load provider SDK if needed
                        if (session.javaScriptSdkUrl) {
                            await MerchelloPayment.loadSdk(session.javaScriptSdkUrl);
                        }

                        // Initialize hosted fields
                        await MerchelloPayment.initializeHostedFields(session, container);
                        this.hostedFieldsReady = true;
                    } catch (error) {
                        console.error('Failed to setup hosted fields:', error);
                        this.paymentError = 'Failed to load card entry form. Please try again.';
                    }
                },

                // Setup widget (Apple Pay, Google Pay, etc.)
                async setupWidget(session) {
                    const container = document.getElementById('payment-widget');
                    if (!container) return;

                    try {
                        // Load provider SDK if needed
                        if (session.javaScriptSdkUrl) {
                            await MerchelloPayment.loadSdk(session.javaScriptSdkUrl);
                        }

                        // Initialize widget
                        await MerchelloPayment.initializeWidget(session, container);
                        this.widgetReady = true;
                    } catch (error) {
                        console.error('Failed to setup widget:', error);
                        this.paymentError = 'Failed to load payment widget. Please try again.';
                    }
                },

                // Setup direct form (manual payment fields)
                async setupDirectForm(session) {
                    const container = document.getElementById('direct-form-fields');
                    if (!container) return;

                    if (session.formFields && session.formFields.length > 0) {
                        container.innerHTML = MerchelloPayment.renderFormFields(session.formFields);
                    }
                },

                // Handle hosted fields submission
                async submitHostedFields() {
                    // This will be called by the SDK when card fields are submitted
                    // Implementation depends on the specific provider SDK
                },

                // Handle direct form submission
                async submitDirectForm() {
                    const session = this.currentSession;
                    if (!session || !session.formFields) return;

                    // Validate form data
                    const validation = MerchelloPayment.validateFormData(session.formFields);
                    if (!validation.isValid) {
                        MerchelloPayment.displayErrors(validation.errors);
                        return;
                    }

                    // Collect form data
                    const formData = MerchelloPayment.collectFormData(session.formFields);

                    // Submit to backend
                    // This would need an additional API endpoint to process direct form submissions
                }
            }
        }
    </script>
