<?xml version="1.0" encoding="utf-8"?>
<DataType Key="7607f5d2-0f72-46ff-933c-d32f06d34df4" Alias="Merchello Product Description [TipTap]" Level="1">
  <Info>
    <Name>Merchello Product Description [TipTap]</Name>
    <EditorAlias>Umbraco.RichText</EditorAlias>
    <EditorUIAlias>Umb.PropertyEditorUi.Tiptap</EditorUIAlias>
  </Info>
  <Config><![CDATA[{
  "extensions": [
    "Umb.Tiptap.RichTextEssentials",
    "Umb.Tiptap.Bold",
    "Umb.Tiptap.Italic",
    "Umb.Tiptap.Underline",
    "Umb.Tiptap.TextAlign",
