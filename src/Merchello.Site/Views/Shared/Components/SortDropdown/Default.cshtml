@model Merchello.Site.Shared.Components.SortDropdown.SortDropdownViewModel
@using Merchello.Core.Products.Models
@using Merchello.Site.Shared.Components.SortDropdown

<div class="sort-dropdown d-flex align-items-center">
    <label for="sortOrder" class="me-2 text-nowrap mb-0">Sort by:</label>
    <select id="sortOrder"
            class="form-select form-select-sm"
            x-model="sortBy"
            @@change="applyFilters()">
        @foreach (var option in SortDropdownViewModel.SortOptions)
        {
            var isSelected = Model.SelectedOrderBy == option.Value;
            if (isSelected)
            {
                <option value="@((int)option.Value)" selected>@option.Label</option>
            }
            else
            {
                <option value="@((int)option.Value)">@option.Label</option>
            }
        }
    </select>
</div>
